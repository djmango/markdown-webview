    <style>
        #markdown-rendered {
    color: -apple-system-label;
    font-family: system-ui;
    font-size: 10pt;
    line-height: 1.5;
    word-wrap: break-word;
}

#markdown-rendered details,
#markdown-rendered figcaption,
#markdown-rendered figure {
    display: block;
}

#markdown-rendered summary {
    display: list-item;
}

#markdown-rendered [hidden] {
    display: none !important;
}

#markdown-rendered a {
    background-color: transparent;
    color: -apple-system-blue;
    text-decoration: none;
}

#markdown-rendered abbr[title] {
    border-bottom: none;
    text-decoration: underline dotted;
}

#markdown-rendered b,
#markdown-rendered strong {
    font-weight: 600;
}

#markdown-rendered dfn {
    font-style: italic;
}

#markdown-rendered h1 {
    margin: .67em 0;
    font-weight: 600;
    font-size: 2em;
}

#markdown-rendered mark {
    background-color: -apple-system-yellow;
}

#markdown-rendered small {
    font-size: 90%;
}

#markdown-rendered sub,
#markdown-rendered sup {
    font-size: 75%;
    line-height: 0;
    position: relative;
    vertical-align: baseline;
}

#markdown-rendered sub {
    bottom: -0.25em;
}

#markdown-rendered sup {
    top: -0.5em;
}

#markdown-rendered img {
    border-style: none;
    max-width: 100%;
    box-sizing: content-box;
}

#markdown-rendered code,
#markdown-rendered kbd,
#markdown-rendered pre,
#markdown-rendered samp {
    font-family: ui-monospace;
    font-size: 1em;
}

#markdown-rendered figure {
    margin: 1em 40px;
}

#markdown-rendered hr {
    box-sizing: content-box;
    overflow: hidden;
    padding: 0;
    margin: 24px 0;
    border: 0;
    border-bottom: thin solid -apple-system-separator;
}

#markdown-rendered input {
    font: inherit;
    margin: 0;
    overflow: visible;
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
}

#markdown-rendered [type=checkbox],
#markdown-rendered [type=radio] {
    box-sizing: border-box;
    padding: 0;
}

#markdown-rendered a:hover {
    text-decoration: underline;
}

#markdown-rendered hr::before {
    display: table;
    content: "";
}

#markdown-rendered hr::after {
    display: table;
    clear: both;
    content: "";
}

#markdown-rendered details summary {
    cursor: pointer;
}

#markdown-rendered details:not([open])>*:not(summary) {
    display: none !important;
}

#markdown-rendered a:focus,
#markdown-rendered [role=button]:focus,
#markdown-rendered input[type=radio]:focus,
#markdown-rendered input[type=checkbox]:focus {
    outline: 2px solid -apple-system-blue;
    outline-offset: -2px;
    box-shadow: none;
}

#markdown-rendered a:focus:not(:focus-visible),
#markdown-rendered [role=button]:focus:not(:focus-visible),
#markdown-rendered input[type=radio]:focus:not(:focus-visible),
#markdown-rendered input[type=checkbox]:focus:not(:focus-visible) {
    outline: solid 1px transparent;
}

